# Capacitor genera estos al ejecutar `cap add android`
android/

# Build output del frontend que se copia
public/

# Node
node_modules/

# Build outputs locales
*.apk
*.aab
*.jks
keystore.properties

# Keystores: las propias del usuario quedan ignored, pero la fija
# del proyecto (localtv.keystore) SÍ se versiona — necesaria para
# que todas las builds firmen consistente y los updates funcionen.
*.keystore
!localtv.keystore
